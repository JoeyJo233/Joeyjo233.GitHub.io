---
import { t, getLocalePath, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="min-h-screen pt-32 pb-20 px-6 bg-white dark:bg-black overflow-hidden relative">
  <!-- Decorative blurred circle -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[1000px] h-[600px] bg-black/5 dark:bg-white/5 blur-[120px] rounded-full pointer-events-none"></div>

  <!-- Grid background pattern -->
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:24px_24px] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto relative">
    <div class="text-center mb-24">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-black/5 dark:bg-white/5 border border-black/10 dark:border-white/10 text-sm font-mono text-black/60 dark:text-white/60 mb-8">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-yellow-500">
          <path d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z"></path>
          <path d="M20 2v4"></path>
          <path d="M22 4h-4"></path>
          <circle cx="4" cy="20" r="2"></circle>
        </svg>
        {t(lang, 'hero.badge')}
      </div>

      <!-- Heading -->
      <h1 class="text-5xl md:text-7xl font-bold tracking-tighter text-black dark:text-white mb-8 leading-[1.1]">
        {t(lang, 'hero.title.line1')}<br class="hidden sm:block" />{t(lang, 'hero.title.line2')}
      </h1>

      <!-- Subtitle -->
      <p class="text-xl md:text-2xl text-black/60 dark:text-white/60 max-w-3xl mx-auto mb-12 leading-relaxed">
        {t(lang, 'hero.subtitle')}
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
        <a
          class="px-8 py-4 bg-black dark:bg-white text-white dark:text-black font-bold rounded-2xl flex items-center gap-2 hover:scale-105 transition-transform shadow-xl"
          href={getLocalePath(lang, '/projects')}
        >
          {t(lang, 'hero.cta.projects')}
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5">
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </a>
        <a
          class="px-8 py-4 bg-black/5 dark:bg-white/5 text-black dark:text-white font-bold rounded-2xl border border-black/10 dark:border-white/10 hover:bg-black/10 dark:hover:bg-white/10 transition-all"
          href={getLocalePath(lang, '/about')}
        >
          {t(lang, 'hero.cta.about')}
        </a>
      </div>
    </div>
  </div>
</section>
