---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import { SITE } from "@/config";
---

<Layout title={`Portfolio | ${SITE.title}`}>
  <Header />
  <Breadcrumb />
  <main id="main-content" class="app-layout mb-28">

    <!-- ── Hero ── -->
    <section class="portfolio-hero">
      <p class="portfolio-label">Portfolio</p>
      <h1 class="portfolio-name">{SITE.author}</h1>
      <p class="portfolio-desc">
        MSc Computer Science · AI Software Developer · Lund, Sweden
      </p>
    </section>

    <!-- ── Experience ── -->
    <section class="section">
      <h2 class="section-title">Experience</h2>

      <div class="timeline">

        <!-- Qlik -->
        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <div class="timeline-card">
            <div class="card-header">
              <div>
                <h3 class="card-company">Qlik</h3>
                <p class="card-role">AI Software Developer Intern</p>
              </div>
              <div class="card-meta">
                <span class="card-period">May 2025 – Present</span>
                <span class="card-location">Lund, Sweden</span>
              </div>
            </div>
            <ul class="card-bullets">
              <li>
                Contributed to <strong>Qlik Answers</strong>, a multi-agent BI system integrated into Qlik Sense, currently in Private Preview with Fortune 500 clients.
              </li>
              <li>
                Designed the <strong>Supervisor Agent</strong> with LangGraph and AWS Bedrock — added intent classification and agent routing, benchmarked Claude / Nova / GPT, and reduced end-to-end latency by <strong>12%</strong>.
              </li>
              <li>
                Built a test-driven QA pipeline for the Analytics Agent using PyTest with unit and E2E tests in CI, achieving <strong>85%+ code coverage</strong>.
              </li>
              <li>
                Developed custom middleware for the <strong>Qlik-MCP</strong> server with OpenTelemetry instrumentation, visualizing span traces in Jaeger for agentic workflow debugging.
              </li>
            </ul>
            <div class="card-tags">
              <span class="tag">LangGraph</span>
              <span class="tag">AWS Bedrock</span>
              <span class="tag">MCP</span>
              <span class="tag">OpenTelemetry</span>
              <span class="tag">PyTest</span>
              <span class="tag">Python</span>
            </div>
          </div>
        </div>

        <!-- VAST Challenge -->
        <div class="timeline-item">
          <div class="timeline-dot timeline-dot--past"></div>
          <div class="timeline-card">
            <div class="card-header">
              <div>
                <h3 class="card-company">VAST Challenge <span class="card-company-sub">(IEEE Visual Analytics)</span></h3>
                <p class="card-role">Data Analyst</p>
              </div>
              <div class="card-meta">
                <span class="card-period">Dec 2023 – Dec 2024</span>
                <span class="card-location">Norrköping, Sweden</span>
              </div>
            </div>
            <ul class="card-bullets">
              <li>
                Analyzed 500,000+ credit card / loyalty transactions and vehicle GPS trajectories; built an interactive system identifying <strong>50+ suspicious patterns</strong>.
                <a href="https://github.com/JoeyJo233/VAST_Challenge_2021_MC2" target="_blank" class="inline-link">[Repo]</a>
              </li>
              <li>
                Used Pandas to clean 10,000+ anomalous records and QGIS to map 500+ GPS trajectories for vehicle movement analysis.
              </li>
              <li>
                Built interactive dashboards with Plotly Dash and a social network graph (100+ entities, 2,000+ relationships) using Dash Cytoscape to surface fraud connections.
              </li>
            </ul>
            <div class="card-tags">
              <span class="tag">Python</span>
              <span class="tag">Pandas</span>
              <span class="tag">QGIS</span>
              <span class="tag">Plotly Dash</span>
              <span class="tag">Dash Cytoscape</span>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- ── Education ── -->
    <section class="section">
      <h2 class="section-title">Education</h2>

      <div class="edu-grid">
        <div class="edu-card">
          <div class="edu-icon">🎓</div>
          <div>
            <h3 class="edu-school">Linköping University</h3>
            <p class="edu-degree">MSc in Computer Science</p>
            <p class="edu-period">Aug 2023 – Dec 2025 · Linköping, Sweden</p>
          </div>
        </div>
        <div class="edu-card">
          <div class="edu-icon">🏫</div>
          <div>
            <h3 class="edu-school">Northwest A&F University</h3>
            <p class="edu-degree">BEng in Computer Science and Technology</p>
            <p class="edu-period">Sep 2019 – Jun 2023 · China</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Skills ── -->
    <section class="section">
      <h2 class="section-title">Technical Skills</h2>

      <div class="skills-grid">
        <div class="skill-group">
          <h4 class="skill-label">Languages</h4>
          <div class="skill-tags">
            <span class="tag">Python</span>
            <span class="tag">Go</span>
            <span class="tag">SQL</span>
            <span class="tag">C++</span>
            <span class="tag">Java</span>
            <span class="tag">TypeScript</span>
          </div>
        </div>
        <div class="skill-group">
          <h4 class="skill-label">AI & Agents</h4>
          <div class="skill-tags">
            <span class="tag">LangGraph</span>
            <span class="tag">AWS Bedrock</span>
            <span class="tag">MCP</span>
            <span class="tag">Multi-Agent Systems</span>
          </div>
        </div>
        <div class="skill-group">
          <h4 class="skill-label">Backend</h4>
          <div class="skill-tags">
            <span class="tag">FastAPI</span>
            <span class="tag">gRPC</span>
            <span class="tag">PostgreSQL</span>
            <span class="tag">MongoDB</span>
            <span class="tag">A2A Protocol</span>
          </div>
        </div>
        <div class="skill-group">
          <h4 class="skill-label">Cloud & DevOps</h4>
          <div class="skill-tags">
            <span class="tag">Kubernetes</span>
            <span class="tag">Docker</span>
            <span class="tag">AWS</span>
            <span class="tag">GitHub Actions</span>
            <span class="tag">ArgoCD</span>
            <span class="tag">OpenTelemetry</span>
          </div>
        </div>
        <div class="skill-group">
          <h4 class="skill-label">Testing & Tools</h4>
          <div class="skill-tags">
            <span class="tag">PyTest</span>
            <span class="tag">gTest</span>
            <span class="tag">Git</span>
            <span class="tag">Linux</span>
            <span class="tag">Jira</span>
            <span class="tag">Agile / Scrum</span>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  /* ── Hero ── */
  .portfolio-hero {
    padding: 3rem 0 2.5rem;
    border-bottom: 1px solid color-mix(in srgb, var(--border) 40%, transparent);
    margin-bottom: 3rem;
  }

  .portfolio-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  .portfolio-name {
    font-size: 2.5rem;
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 0.75rem;
  }

  .portfolio-desc {
    font-size: 1rem;
    opacity: 0.6;
  }

  /* ── Section ── */
  .section {
    margin-bottom: 3.5rem;
  }

  .section-title {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid color-mix(in srgb, var(--border) 30%, transparent);
  }

  /* ── Timeline ── */
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    position: relative;
    padding-left: 1.5rem;
  }

  .timeline::before {
    content: "";
    position: absolute;
    left: 0.3rem;
    top: 0.6rem;
    bottom: 0.6rem;
    width: 1px;
    background: linear-gradient(
      to bottom,
      var(--accent),
      color-mix(in srgb, var(--border) 40%, transparent)
    );
  }

  .timeline-item {
    position: relative;
  }

  .timeline-dot {
    position: absolute;
    left: -1.22rem;
    top: 1.1rem;
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 8px color-mix(in srgb, var(--accent) 50%, transparent);
  }

  .timeline-dot--past {
    background: color-mix(in srgb, var(--foreground) 30%, transparent);
    box-shadow: none;
  }

  /* ── Card ── */
  .timeline-card {
    border: 1px solid color-mix(in srgb, var(--border) 40%, transparent);
    border-radius: 0.75rem;
    padding: 1.25rem 1.5rem;
    background: color-mix(in srgb, var(--foreground) 2%, var(--background));
    transition: border-color 0.2s ease;
  }

  .timeline-card:hover {
    border-color: color-mix(in srgb, var(--accent) 30%, transparent);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .card-company {
    font-size: 1.05rem;
    font-weight: 700;
    margin: 0;
  }

  .card-company-sub {
    font-size: 0.8rem;
    font-weight: 400;
    opacity: 0.5;
  }

  .card-role {
    font-size: 0.875rem;
    opacity: 0.65;
    margin: 0.15rem 0 0;
  }

  .card-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.2rem;
    flex-shrink: 0;
  }

  .card-period {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--accent);
  }

  .card-location {
    font-size: 0.75rem;
    opacity: 0.45;
  }

  .card-bullets {
    list-style: none;
    padding: 0;
    margin: 0 0 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .card-bullets li {
    font-size: 0.875rem;
    line-height: 1.6;
    opacity: 0.8;
    padding-left: 1rem;
    position: relative;
  }

  .card-bullets li::before {
    content: "·";
    position: absolute;
    left: 0;
    color: var(--accent);
    font-weight: 700;
  }

  .inline-link {
    color: var(--accent);
    text-decoration: none;
    font-weight: 600;
    margin-left: 0.25rem;
  }

  .inline-link:hover {
    text-decoration: underline;
  }

  /* ── Tags ── */
  .card-tags,
  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--accent) 20%, transparent);
    color: color-mix(in srgb, var(--accent) 80%, var(--foreground));
    background: color-mix(in srgb, var(--accent) 8%, transparent);
    letter-spacing: 0.02em;
  }

  /* ── Education ── */
  .edu-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .edu-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .edu-card {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    border: 1px solid color-mix(in srgb, var(--border) 40%, transparent);
    border-radius: 0.75rem;
    padding: 1.25rem;
    background: color-mix(in srgb, var(--foreground) 2%, var(--background));
    transition: border-color 0.2s ease;
  }

  .edu-card:hover {
    border-color: color-mix(in srgb, var(--accent) 30%, transparent);
  }

  .edu-icon {
    font-size: 1.75rem;
    flex-shrink: 0;
  }

  .edu-school {
    font-size: 0.95rem;
    font-weight: 700;
    margin: 0 0 0.2rem;
  }

  .edu-degree {
    font-size: 0.85rem;
    opacity: 0.7;
    margin: 0 0 0.25rem;
  }

  .edu-period {
    font-size: 0.75rem;
    opacity: 0.45;
    margin: 0;
  }

  /* ── Skills ── */
  .skills-grid {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .skill-group {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .skill-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    opacity: 0.5;
    text-transform: uppercase;
    flex-shrink: 0;
    width: 7rem;
  }
</style>
