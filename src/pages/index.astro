---
import '../styles/global.css';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import FeaturedSection from '../components/FeaturedSection.astro';
import Footer from '../components/Footer.astro';

const lang = 'en' as const;
---

<Layout title="Joey's Space - Home" description="Welcome to my personal space. Explore my projects, blog posts, and career journey." lang={lang}>
  <div class="min-h-screen flex flex-col">
    <Header lang={lang} currentPath={Astro.url.pathname} />
    <main class="flex-grow pt-20">
      <Hero lang={lang} />
      <FeaturedSection lang={lang} />
    </main>
    <Footer lang={lang} />
  </div>
</Layout>
