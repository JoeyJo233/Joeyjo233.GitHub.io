---
import '../../styles/global.css';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { t } from '../../i18n/utils';

const lang = 'en' as const;

const contactMethods = [
  {
    title: t(lang, 'contact.email.title'),
    desc: t(lang, 'contact.email.desc'),
    href: "mailto:placeholder@example.com",
    icon: "mail",
  },
  {
    title: t(lang, 'contact.github.title'),
    desc: t(lang, 'contact.github.desc'),
    href: "https://github.com/Joeyjo233",
    icon: "github",
    external: true,
  },
  {
    title: t(lang, 'contact.social.title'),
    desc: t(lang, 'contact.social.desc'),
    href: "#",
    icon: "social",
  },
];
---

<Layout title={`${t(lang, 'contact.title')} - Joey's Space`} description={t(lang, 'contact.subtitle')} lang={lang}>
  <div class="min-h-screen flex flex-col">
    <Header lang={lang} currentPath={Astro.url.pathname} />
    <main class="flex-grow pt-20">
      <div class="min-h-screen pt-32 pb-20 px-6 bg-white dark:bg-black relative overflow-hidden">
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:24px_24px] pointer-events-none"></div>

        <div class="max-w-4xl mx-auto relative">
          <div class="text-center mb-20">
            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-black/5 dark:bg-white/5 border border-black/10 dark:border-white/10 text-sm font-mono text-black/60 dark:text-white/60 mb-8">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
                <rect width="20" height="16" x="2" y="4" rx="2"></rect>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
              </svg>
              {t(lang, 'contact.badge')}
            </div>
            <h1 class="text-5xl md:text-7xl font-bold tracking-tighter text-black dark:text-white mb-8 leading-[1.1]">
              {t(lang, 'contact.title')}
            </h1>
            <p class="text-xl text-black/60 dark:text-white/60 max-w-2xl mx-auto">
              {t(lang, 'contact.subtitle')}
            </p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
            {contactMethods.map((method) => (
              <a
                href={method.href}
                target={method.external ? "_blank" : undefined}
                rel={method.external ? "noopener noreferrer" : undefined}
                class="p-6 rounded-3xl border border-black/10 dark:border-white/10 bg-white/50 dark:bg-white/5 backdrop-blur-sm hover:shadow-lg transition-all group text-center"
              >
                <div class="w-14 h-14 rounded-full bg-black/5 dark:bg-white/10 flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform">
                  {method.icon === "mail" && (
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-black/60 dark:text-white/60">
                      <rect width="20" height="16" x="2" y="4" rx="2"></rect>
                      <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
                    </svg>
                  )}
                  {method.icon === "github" && (
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-black/60 dark:text-white/60">
                      <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path>
                      <path d="M9 18c-4.51 2-5-2-7-2"></path>
                    </svg>
                  )}
                  {method.icon === "social" && (
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-black/60 dark:text-white/60">
                      <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
                      <rect width="4" height="12" x="2" y="9"></rect>
                      <circle cx="4" cy="4" r="2"></circle>
                    </svg>
                  )}
                </div>
                <h3 class="text-lg font-bold text-black dark:text-white mb-2">{method.title}</h3>
                <p class="text-sm text-black/50 dark:text-white/50">{method.desc}</p>
              </a>
            ))}
          </div>

          <div class="p-8 rounded-[40px] bg-black dark:bg-zinc-900 border border-white/10 relative overflow-hidden">
            <div class="absolute top-0 right-0 w-64 h-64 bg-blue-500/10 blur-[120px]"></div>
            <div class="absolute bottom-0 left-0 w-64 h-64 bg-purple-500/10 blur-[120px]"></div>

            <div class="relative">
              <h2 class="text-2xl font-bold text-white mb-8 text-center">{t(lang, 'contact.form.title')}</h2>
              <form class="space-y-6 max-w-lg mx-auto">
                <div>
                  <label class="block text-sm text-white/60 mb-2 font-mono">{t(lang, 'contact.form.name')}</label>
                  <input
                    type="text"
                    class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder:text-white/30 focus:outline-none focus:border-white/30 transition-colors"
                    placeholder={t(lang, 'contact.form.name')}
                  />
                </div>
                <div>
                  <label class="block text-sm text-white/60 mb-2 font-mono">{t(lang, 'contact.form.email')}</label>
                  <input
                    type="email"
                    class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder:text-white/30 focus:outline-none focus:border-white/30 transition-colors"
                    placeholder={t(lang, 'contact.form.email')}
                  />
                </div>
                <div>
                  <label class="block text-sm text-white/60 mb-2 font-mono">{t(lang, 'contact.form.message')}</label>
                  <textarea
                    rows="5"
                    class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder:text-white/30 focus:outline-none focus:border-white/30 transition-colors resize-none"
                    placeholder={t(lang, 'contact.form.message')}
                  ></textarea>
                </div>
                <button
                  type="submit"
                  class="w-full py-4 bg-white text-black font-bold rounded-2xl hover:bg-white/90 transition-colors flex items-center justify-center gap-2"
                >
                  {t(lang, 'contact.form.send')}
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5">
                    <path d="M5 12h14"></path>
                    <path d="m12 5 7 7-7 7"></path>
                  </svg>
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </main>
    <Footer lang={lang} />
  </div>
</Layout>
