---
import { t, getLocalePath, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const sections = [
  {
    title: t(lang, 'footer.section.projects'),
    links: [
      { text: t(lang, 'footer.link.project1'), href: getLocalePath(lang, '/projects') },
      { text: t(lang, 'footer.link.project2'), href: getLocalePath(lang, '/projects') },
      { text: t(lang, 'footer.link.project3'), href: getLocalePath(lang, '/projects') },
    ],
  },
  {
    title: t(lang, 'footer.section.content'),
    links: [
      { text: t(lang, 'footer.link.blog'), href: getLocalePath(lang, '/blog') },
      { text: t(lang, 'footer.link.notes'), href: getLocalePath(lang, '/blog') },
    ],
  },
  {
    title: t(lang, 'footer.section.contact'),
    links: [
      { text: "GitHub", href: "https://github.com/Joeyjo233", external: true },
      { text: "Email", href: "mailto:placeholder@example.com" },
    ],
  },
];
---

<footer class="w-full border-t border-black/10 dark:border-white/10 bg-white/50 dark:bg-black/50 backdrop-blur-xl py-12 px-6 mt-auto">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
      <!-- Logo -->
      <div class="col-span-1 md:col-span-1">
        <a class="flex items-center gap-3 group" href={getLocalePath(lang, '/')}>
          <div class="w-8 h-8 bg-black dark:bg-white rounded-lg flex items-center justify-center group-hover:rotate-6 transition-transform duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white dark:text-black w-5 h-5">
              <path d="M12 19h8"></path>
              <path d="m4 17 6-6-6-6"></path>
            </svg>
          </div>
          <span class="font-bold text-lg tracking-tight text-black dark:text-white">Joey's Space</span>
        </a>
      </div>

      <!-- Link sections -->
      {sections.map((section) => (
        <div>
          <h3 class="text-xs font-bold uppercase tracking-widest text-black/40 dark:text-white/40 mb-4">
            {section.title}
          </h3>
          <ul class="space-y-3">
            {section.links.map((link) => (
              <li>
                <a
                  class="text-sm text-black/60 dark:text-white/60 hover:text-black dark:hover:text-white transition-colors flex items-center gap-1 group"
                  href={link.href}
                  target={link.external ? "_blank" : undefined}
                  rel={link.external ? "noopener noreferrer" : undefined}
                >
                  {link.text}
                  {link.external && (
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity">
                      <path d="M15 3h6v6"></path>
                      <path d="M10 14 21 3"></path>
                      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                    </svg>
                  )}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Copyright -->
    <div class="mt-12 pt-8 border-t border-black/5 dark:border-white/5 text-center">
      <div class="text-[11px] text-black/40 dark:text-white/40 max-w-2xl mx-auto space-y-1">
        <p>&copy; {new Date().getFullYear()} Joey's Space. {t(lang, 'footer.copyright')}</p>
        <p class="leading-[1.4]">{t(lang, 'footer.slogan')}</p>
      </div>
    </div>
  </div>
</footer>
