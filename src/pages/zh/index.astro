---
import '../../styles/global.css';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import FeaturedSection from '../../components/FeaturedSection.astro';
import Footer from '../../components/Footer.astro';

const lang = 'zh' as const;
---

<Layout title="Joey's Space - 个人主页" description="欢迎来到我的个人空间，这里有我的项目作品、技术博客和职业经历。" lang={lang}>
  <div class="min-h-screen flex flex-col">
    <Header lang={lang} currentPath={Astro.url.pathname} />
    <main class="flex-grow pt-20">
      <Hero lang={lang} />
      <FeaturedSection lang={lang} />
    </main>
    <Footer lang={lang} />
  </div>
</Layout>
