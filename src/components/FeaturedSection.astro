---
import { t, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const projects = [
  {
    title: t(lang, 'featured.project1.title'),
    description: t(lang, 'featured.project1.desc'),
    icon: "code",
    tags: ["React", "Node.js", "MongoDB"],
  },
  {
    title: t(lang, 'featured.project2.title'),
    description: t(lang, 'featured.project2.desc'),
    icon: "layout",
    tags: ["TypeScript", "Tailwind", "Astro"],
  },
  {
    title: t(lang, 'featured.project3.title'),
    description: t(lang, 'featured.project3.desc'),
    icon: "package",
    tags: ["Python", "API", "CLI"],
  },
];
---

<section id="projects" class="px-6 pb-32 bg-white dark:bg-black relative">
  <div class="max-w-4xl mx-auto relative">
    <div class="p-12 rounded-[40px] bg-black dark:bg-zinc-900 border border-white/10 relative overflow-hidden">
      <!-- Decorative blurs -->
      <div class="absolute top-0 right-0 w-64 h-64 bg-blue-500/10 blur-[120px]"></div>
      <div class="absolute bottom-0 left-0 w-64 h-64 bg-purple-500/10 blur-[120px]"></div>

      <!-- Title -->
      <div class="text-center mb-12 relative">
        <h2 class="text-3xl font-bold text-white">{t(lang, 'featured.title')}</h2>
      </div>

      <!-- Project Cards Grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 relative">
        {projects.map((project) => (
          <div class="p-6 rounded-3xl bg-white/5 border border-white/5 backdrop-blur-sm flex flex-col items-center text-center">
            <!-- Icon -->
            <div class="w-16 h-16 rounded-full overflow-hidden mb-4 border-2 border-white/10 bg-white/5 flex items-center justify-center">
              {project.icon === "code" && (
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7 text-white/80">
                  <polyline points="16 18 22 12 16 6"></polyline>
                  <polyline points="8 6 2 12 8 18"></polyline>
                </svg>
              )}
              {project.icon === "layout" && (
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7 text-white/80">
                  <rect width="18" height="18" x="3" y="3" rx="2"></rect>
                  <path d="M3 9h18"></path>
                  <path d="M9 21V9"></path>
                </svg>
              )}
              {project.icon === "package" && (
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7 text-white/80">
                  <path d="M11 21.73a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73z"></path>
                  <path d="M12 22V12"></path>
                  <path d="m3.3 7 7.703 4.734a2 2 0 0 0 1.994 0L20.7 7"></path>
                </svg>
              )}
            </div>

            <!-- Title -->
            <h3 class="text-lg font-bold text-white mb-2">{project.title}</h3>

            <!-- Description -->
            <p class="text-sm text-white/50 mb-4 leading-relaxed">{project.description}</p>

            <!-- Tags -->
            <div class="flex flex-wrap gap-2 justify-center">
              {project.tags.map((tag) => (
                <span class="px-3 py-1 rounded-xl bg-white/5 text-xs text-white/60 font-mono">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
